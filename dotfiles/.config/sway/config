# Some variables.
set $mod Mod1
set $left h
set $down j
set $up k
set $right l
set $term foot
set $menu-args -i -f 'JetBrainsMono Nerd Font 12' -N 000000 -n ffffff
set $launcher wmenu-run $menu-args
set $menu wmenu $menu-args
set $screenshot_cmd grim && notify-send "Screenshot taken."

# Various settings.
floating_modifier $mod normal
hide_edge_borders smart
focus_follows_mouse no
font pango:JetBrainsMono Nerd Font 12

# Hide window title bar.
default_border pixel 3
default_floating_border pixel 1
for_window [class="^.*"] border pixel 3

# Startup applications.
exec wl-paste --watch cliphist store
exec swaybg -i ~/wallpapers/dark-pen.jpg
exec mako
exec lxsession
exec foot --app-id=pulsemixer pulsemixer
exec foot --app-id=dropdown --override=initial-window-size-pixels=1200x750
exec swayidle -w \
         timeout 600 'swaylock' \
         timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
         before-sleep 'swaylock'

# Touchpad configuration.
input type:touchpad {
    dwt enabled
    tap disable
    natural_scroll enabled
    middle_emulation enabled
}

# Keyboard configuration.
input type:keyboard {
    xkb_layout "eu"
    xkb_options "ctrl:nocaps"
}

# Various.
bindsym $mod+q kill
bindsym $mod+f fullscreen
bindsym $mod+Shift+c exec cliphist wipe

# Scritps (wmenu).
bindsym $mod+b exec wmenu-books $menu-args
bindsym $mod+d exec wmenu-kill $menu-args
bindsym $mod+c exec wmenu-clipboard $menu-args
bindsym $mod+r exec wmenu-rfc $menu-args

# Essential keymaps.
bindsym $mod+Escape exec swaylock
bindsym $mod+Return exec $term
bindsym $mod+p exec $launcher
bindsym $mod+Shift+e exec swaynag -t warning -m '' -B 'Yes, exit sway' 'swaymsg exit'

# Reload this config file.
bindsym $mod+Shift+r reload

# Move windows around.
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Change the focus.
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Layout controls.
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Floating windows.
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Workspaces selection.
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Move windows around workspaces.
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Input/Output audio.
bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle
bindsym --locked $mod+m exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked $mod+u exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked $mod+i exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked $mod+n exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle

# Brightness controls.
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 10%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 10%+

# Screenshots utility.
bindsym Print exec $screenshot_cmd
bindsym $mod+Shift+s exec $screenshot_cmd

# Scratchpads.
bindsym $mod+Shift+a exec foot --app-id=pulsemixer pulsemixer
bindsym $mod+a [app_id="pulsemixer"] scratchpad show; move position center
bindsym $mod+Shift+t exec foot --app-id=dropdown --override=initial-window-size-pixels=1200x750
bindsym $mod+t [app_id="dropdown"] scratchpad show; move position center

# Resize windows.
bindsym $mod+Ctrl+$left resize shrink width 20px
bindsym $mod+Ctrl+$down resize grow height 20px
bindsym $mod+Ctrl+$up resize shrink height 20px
bindsym $mod+Ctrl+$right resize grow width 20px
bindsym $mod+Ctrl+Left resize shrink width 20px
bindsym $mod+Ctrl+Down resize grow height 20px
bindsym $mod+Ctrl+Up resize shrink height 20px
bindsym $mod+Ctrl+Right resize grow width 20px

# Rules.
for_window [app_id="pulsemixer"] move scratchpad
for_window [app_id="dropdown"] move scratchpad
for_window [app_id="org.pwmt.zathura"] floating enable
for_window [app_id="rfc"] floating enable

# Statusbar.
bar {
    position bottom
    status_command ~/.config/sway/bar
    colors {
        background #000000
    }
}

# Source system-wide sway drop-in files.
include /etc/sway/config.d/*
