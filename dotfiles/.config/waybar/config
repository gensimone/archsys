{
  "layer": "bottom",
  "position": "top",
  "reload_style_on_change": true,
  "mode": "dock",
  "height": 36,
  "width": 1350,
  "margin": "8 8 8 8",
  "spacing": 13,
  "exclusive": false,
  "modules-left": ["network"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "idle_inhibitor", "battery"],

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": " ",
      "deactivated": " "
    }
  },

  "battery": {
    "bat": "BAT0",
    "interval": 60,
    "format": "B: {capacity}%",
  }
}
