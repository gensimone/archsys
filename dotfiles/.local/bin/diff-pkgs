#!/bin/sh

# This looks crap, I know.

host_pkgs_path=/tmp/pkgs
repo_pkgs_path=$HOME/codes/archsys/pkgs

pacman -Qei | grep Name | awk '{print $3}' > $host_pkgs_path

partial_pkgs_path=/tmp/partial_pkgs
grep -vxf $repo_pkgs_path $host_pkgs_path > $partial_pkgs_path

# The following packages must be deleted from partial_result:
# FIXME
pkgs_to_ignore_path=/tmp/pkgs_to_ignore
cat <<EOF | sudo tee $pkgs_to_ignore_path 1>/dev/null
base
efibootmgr
intel-ucode
linux-firmware
linux-lts
sof-firmware
sof-firmware
sudo
wpa_supplicant
zram-generator
EOF

grep -vxf $pkgs_to_ignore_path $partial_pkgs_path
