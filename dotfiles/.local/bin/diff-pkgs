#!/usr/bin/perl

use strict;
use warnings;

my $root = "$ENV{'HOME'}/codes/archsys";
my $pkgs = `$root/dotfiles/.local/bin/sphinx $root/pkgs`;
my $pkgs_to_exclude = "
base
efibootmgr
intel-ucode
linux
linux-firmware
linux-lts
linux-zen
sof-firmware
sudo
wpa_supplicant
zram-generator
";

my @installed_pkgs;
foreach (`pacman -Qei`) {
    if (/^Name\s+:\s(.*)\s*$/) {
        push @installed_pkgs, $1;
    }
}

sub diff_installed_pkgs {
    my @diff_installed_pkgs;
    foreach my $pkg (@installed_pkgs) {
        if ($pkgs_to_exclude !~ /\b$pkg\b/ and $pkgs !~ /\b$pkg\b/) {
            push @diff_installed_pkgs, $pkg;
        }
    }
    if (@diff_installed_pkgs) {
        print "Installed:\n";
        print "  $_\n" foreach @diff_installed_pkgs;
    }
}

sub diff_removed_pkgs {
    my @diff_removed_pkgs;
    foreach my $pkg (split /\n/, $pkgs) {
        unless ($pkg ~~ @installed_pkgs) {
            push @diff_removed_pkgs, $pkg;
        }
    }
    if (@diff_removed_pkgs) {
        print "Removed:\n";
        print "  $_\n" foreach @diff_removed_pkgs;
    }
}

diff_installed_pkgs();
diff_removed_pkgs();
