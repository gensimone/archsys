#!/bin/sh

pkgs=$(cat $HOME/codes/archsys/pkgs)

pkgs_to_exclude="
    base           \
    efibootmgr     \
    intel-ucode    \
    linux-firmware \
    linux-lts      \
    sof-firmware   \
    sudo           \
    wpa_supplicant \
    zram-generator"

# Installed packages.
installed_pkgs=$(pacman -Qei | grep Name | awk '{print $3}')
diff_installed_pkgs=
for pkg in $installed_pkgs; do
    if [[ "$pkgs_to_exclude" != *"$pkg"* ]] && [[ "$pkgs" != *"$pkg"* ]]; then
        diff_installed_pkgs="$diff_installed_pkgs $pkg"
    fi
done
if [ -n "$diff_installed_pkgs" ]; then
    echo "Installed:"
    for pkg in $diff_installed_pkgs; do
        echo "  $pkg"
    done
fi

# Removed packages.
diff_removed_pkgs=
for pkg in $pkgs; do
    if [[ "$installed_pkgs" != *"$pkg"* ]]; then
        diff_removed_pkgs="$diff_removed_pkgs $pkg"
    fi
done
if [ -n "$diff_removed_pkgs" ]; then
    echo "Removed:"
    for pkg in $diff_removed_pkgs; do
        echo "  $pkg"
    done
fi
