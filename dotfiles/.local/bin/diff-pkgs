#!/bin/sh

pkgs=$(cat $HOME/codes/archsys/pkgs)

pkgs_to_exclude="
    base           \
    efibootmgr     \
    intel-ucode    \
    linux-firmware \
    linux-lts      \
    sof-firmware   \
    sudo           \
    wpa_supplicant \
    zram-generator"

echo "Installed:"
installed_pkgs=$(pacman -Qei | grep Name | awk '{print $3}')
for pkg in $installed_pkgs; do
    if [[ "$pkgs_to_exclude" != *"$pkg"* ]] && [[ "$pkgs" != *"$pkg"* ]]; then
        echo "  $pkg"
    fi
done

echo

echo "Removed:"
for pkg in $pkgs; do
    if [[ "$installed_pkgs" != *"$pkg"* ]]; then
        echo "  $pkg"
    fi
done
