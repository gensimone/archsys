#!/usr/bin/perl

# Author: Simone Gentili
# More wmenu scripts at https://github.com/gensimone/archsys

use strict;
use warnings;
use Getopt::Long;
use POSIX qw/ setpgid /;

sub preserve_quoted_args {
    my $args = "";
    while (my $arg = shift @ARGV) {
        $args = "$args $arg";
        if ($arg eq "-f" or $arg eq "-p") {
            my $font = shift @ARGV;
            $args = "$args '$font'";
        }
    }
    $args;
}

sub get_wifi_devs {
    my @devices = `nmcli device`;
    my @wifi_devs = ();
    while (my $line = shift @devices) {
        if ($line =~ / wifi /) {
            my @fields = split / /, $line;
            push @wifi_devs, $fields[0];
        }
    }
    @wifi_devs;
}

sub call_wmenu {
    my $args = shift;
    my $entries = shift || "";
    my $bg = shift || "";
    my $lines = shift || scalar(split /\n/, $entries);

    my $wmenu_cmd = sprintf("printf '%s' | wmenu %s -l %d %s", $entries, $args, $lines, $bg);
    `$wmenu_cmd`;
}

sub connect_bssid {
    my $bssid = shift;
    my $args = shift || "";
    my $wait = shift || 90;
    system("nmcli device wifi connect $bssid");
    if ($?) {
        my $passwd = call_wmenu(join(" ", $args, "-P -p 'Password:'"));
        exit 0 unless $passwd;
        `printf "$passwd" | nmcli --wait $wait device wifi connect $bssid --ask`;
    }
}

sub get_device {
    my $args = shift || "";
    my @wifi_devs = get_wifi_devs();
    my $dev;
    if (@wifi_devs == 0) {
        die "No wifi devices detected.";
    } elsif (@wifi_devs == 1) {
        $dev = shift @wifi_devs;
    } else {
        $dev = call_wmenu(join(" ", $args, "-p 'Device':"), join("\n", @wifi_devs));
        exit 0 unless $dev;
    }
    $dev
}

sub get_aps {
    my $dev = shift;
    my $rescan = shift || "yes";
    my $args = shift || "";

    my $scanning_pid;
    if ($rescan =~ /^(auto|yes)$/) {
        $scanning_pid = fork();
        die "fork: $!" unless defined $scanning_pid;
        if ($scanning_pid == 0) {
            setpgid(0, 0);
            call_wmenu(join(" ", $args, "-p 'Scanning...'"));

            # If the user presses 'Escape' we must exit here
            # to prevent the execution of other code.
            # TODO: If the user presses 'Escape' we want to
            #       exit the application entirely.
            exit 0
        }
    }

    my $aps = `nmcli device wifi list --rescan $rescan ifname $dev`;
    exit $? if $?;

    if ($scanning_pid) {
        kill '-KILL', $scanning_pid;
        waitpid($scanning_pid, 0);
    }

    $aps;
}

my $dev;
my $rescan = "no";
my $wait = 3;
GetOptions (
    "ifname=s" => \$dev,
    "rescan=s" => \$rescan,
    "wait=i" => \$wait,
) or exit 1;

my $args = preserve_quoted_args(); # String version of @ARGV with quoted args.
                                   # Do you know a better way?

$dev = get_device($args) unless ($dev);

my $aps = get_aps($dev, $rescan, $args);

my $ap_info = call_wmenu($args, $aps);
exit 0 unless $ap_info;
exit 0 if $ap_info =~ /.*IN-USE.*SECURITY.*$/; # The user selected the header line.

my @ap_fields = split / +/, $ap_info;
my $bssid = $ap_fields[1];  # Assuming BSSID in the second field (first field is a space).
if ($ap_fields[0] eq "*") { # Already connected access point selected.
    `nmcli device disconnect $dev`;
    exit 0;
}
connect_bssid($bssid, $args, $wait);
