#!/usr/bin/perl

# Author: Simone Gentili

use strict;
use warnings;

`nmcli device | grep wifi`;
die "Missing wifi card.\n" if $?;

my $access_points = `nmcli device wifi list --rescan no`;
die "No access points detected.\n" unless ($access_points);

my @lines = split /\n/, $access_points;
my $entries = "";
my $count = 0;
shift @lines;
for (@lines) {
    unless (/^\*/) {
        no warnings;
        $entries = $entries . sprintf("%s %s %s %s %s %s %s %s %s\n", split);
        $count++;
    }
}

my $args = "";
while (my $arg = shift @ARGV) {
    $args = "$args $arg";
    if ($arg eq "-f" or $arg eq "-p") {
        my $font = shift @ARGV;
        $args = "$args '$font'";
    }
}

printf "$args\n";

my $get_entry_cmd = sprintf("printf '%s' | wmenu %s -l %d", $entries, $args, $count);
my $entry = `$get_entry_cmd`;
exit 0 unless $entry;

my @fields = split / /, $entry;
my $bssid = shift @fields;

system("nmcli device wifi connect $bssid");
if ($?) {
    my $get_passwd_cmd = sprintf("printf '' | wmenu %s -P -p 'Password:'", $args);
    my $passwd = `$get_passwd_cmd`;
    exit 0 unless $passwd;
    `printf "$passwd" | nmcli device wifi connect $bssid --ask`;
}
